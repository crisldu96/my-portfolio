allure-results/*
!allure-results/.gitkeep
!allure-results/environment.properties

# Playwright MCP
.playwright-mcp/

# Debug/temp screenshots
*.png
!public/**/*.png
!src/**/*.png

# Temp snapshots
header-snapshot.yml

# Spotify auth script (unused)
scripts/

# Claude local settings
.claude/settings.local.json
