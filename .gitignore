# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local

# vercel
.vercel

# design reference files
.design-reference/

# typescript
*.tsbuildinfo
# next-env.d.ts
next-env.d.ts
.qodo

# Test reports (generated artifacts)
coverage/
playwright-report/
blob-report/
allure-report/
allure-history/
test-results/
